            { "name": "Your (client) IP Address", "value": "192.168.1.150", "highlight": true, "description": "Offered IP address" },
            { "name": "Server IP Address", "value": "192.168.1.1" },
            { "name": "DHCP Message Type", "value": "Offer (2)", "highlight": true },
            { "name": "Option 1 - Subnet Mask", "value": "255.255.255.0", "highlight": true },
