            { "name": "DHCP Message Type", "value": "Discover (1)", "highlight": true },
            { "name": "Option 55 - Parameter Request", "value": "Subnet Mask, Router, DNS, Domain Name, Lease Time", "description": "Parameters the client wants to receive" },
            { "name": "Option 61 - Client ID", "value": "00:50:56:c0:00:08" },
            { "name": "Option 12 - Hostname", "value": "workstation-07" }
          ]
        }
      ]
    },
    {
      "number": 2,
