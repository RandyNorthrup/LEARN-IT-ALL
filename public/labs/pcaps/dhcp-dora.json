      "layers": [
        {
          "name": "Internet Protocol Version 4",
          "fields": [
            { "name": "Source Address", "value": "192.168.1.1" },
            { "name": "Destination Address", "value": "255.255.255.255" }
          ]
        },
        {
          "name": "Dynamic Host Configuration Protocol (ACK)",
          "fields": [
            { "name": "Transaction ID", "value": "0x3903F326" },
            { "name": "Your (client) IP Address", "value": "192.168.1.150", "highlight": true, "description": "Confirmed — client can now use this IP" },
            { "name": "DHCP Message Type", "value": "ACK (5)", "highlight": true, "description": "Server confirms the lease" },
            { "name": "Option 1 - Subnet Mask", "value": "255.255.255.0" },
            { "name": "Option 3 - Default Router", "value": "192.168.1.1" },
            { "name": "Option 6 - DNS Servers", "value": "8.8.8.8, 8.8.4.4" },
            { "name": "Option 51 - Lease Time", "value": "86400 seconds" },
            { "name": "Option 58 - Renewal (T1)", "value": "43200 seconds" },
            { "name": "Option 59 - Rebinding (T2)", "value": "75600 seconds" }
          ]
        }
      ]
    },
    {
      "number": 5,
