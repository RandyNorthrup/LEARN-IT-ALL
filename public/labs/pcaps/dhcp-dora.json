            { "name": "Type", "value": "0x0806", "highlight": true, "description": "ARP" }
          ]
        },
        {
          "name": "Address Resolution Protocol",
          "fields": [
            { "name": "Opcode", "value": "Request (1)" },
            { "name": "Sender MAC", "value": "00:50:56:c0:00:08" },
            { "name": "Sender IP", "value": "192.168.1.150" },
            { "name": "Target MAC", "value": "00:00:00:00:00:00" },
            { "name": "Target IP", "value": "192.168.1.150", "highlight": true, "description": "Gratuitous ARP: Checks for duplicate IP. If reply received, IP conflict detected!" }
          ]
        }
      ]
    },
    {
      "number": 6,
      "timestamp": "1800.000000",
      "source": "192.168.1.150",
      "destination": "192.168.1.1",
