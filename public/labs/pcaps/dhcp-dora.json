            { "name": "Option 15 - Domain Name", "value": "lab.local" },
            { "name": "Option 51 - Lease Time", "value": "86400 seconds (24 hours)", "highlight": true },
            { "name": "Option 58 - Renewal (T1)", "value": "43200 seconds (12 hours)", "description": "Client renews at 50% of lease" },
            { "name": "Option 59 - Rebinding (T2)", "value": "75600 seconds (21 hours)", "description": "Client broadcasts renewal at 87.5% of lease" },
            { "name": "Option 54 - DHCP Server ID", "value": "192.168.1.1" }
          ]
        }
      ]
    },
    {
      "number": 3,
      "timestamp": "0.004100",
      "source": "0.0.0.0",
      "destination": "255.255.255.255",
