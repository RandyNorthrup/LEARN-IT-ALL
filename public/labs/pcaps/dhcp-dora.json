          "fields": [
            { "name": "Source Port", "value": "68", "highlight": true, "description": "DHCP Client port (BOOTP client)" },
            { "name": "Destination Port", "value": "67", "highlight": true, "description": "DHCP Server port (BOOTP server)" }
          ]
        },
        {
          "name": "Dynamic Host Configuration Protocol (Discover)",
          "fields": [
            { "name": "Message Type", "value": "Boot Request (1)" },
            { "name": "Hardware Type", "value": "Ethernet (0x01)" },
            { "name": "Hardware Address Length", "value": "6" },
            { "name": "Transaction ID", "value": "0x3903F326", "highlight": true, "description": "Random ID to match responses" },
