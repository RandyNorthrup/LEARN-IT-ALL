      "info": "DHCP Offer - Transaction ID 0x3903F326",
      "layers": [
        {
          "name": "Ethernet II",
          "fields": [
            { "name": "Destination", "value": "ff:ff:ff:ff:ff:ff", "description": "Broadcast — client can't receive unicast yet" },
            { "name": "Source", "value": "00:0c:29:3e:5a:1b", "description": "DHCP server MAC" }
          ]
        },
        {
          "name": "Internet Protocol Version 4",
          "fields": [
            { "name": "Source Address", "value": "192.168.1.1", "description": "DHCP server IP" },
            { "name": "Destination Address", "value": "255.255.255.255" }
          ]
        },
        {
          "name": "User Datagram Protocol",
          "fields": [
            { "name": "Source Port", "value": "67", "description": "DHCP Server" },
            { "name": "Destination Port", "value": "68", "description": "DHCP Client" }
          ]
        },
        {
          "name": "Dynamic Host Configuration Protocol (Offer)",
          "fields": [
            { "name": "Message Type", "value": "Boot Reply (2)" },
