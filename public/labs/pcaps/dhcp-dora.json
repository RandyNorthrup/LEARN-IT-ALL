      "layers": [
        {
          "name": "Ethernet II",
          "fields": [
            { "name": "Destination", "value": "ff:ff:ff:ff:ff:ff", "highlight": true, "description": "Broadcast — informs ALL servers which offer was accepted" },
            { "name": "Source", "value": "00:50:56:c0:00:08" }
          ]
        },
        {
          "name": "Internet Protocol Version 4",
          "fields": [
            { "name": "Source Address", "value": "0.0.0.0", "highlight": true, "description": "Still no IP — not confirmed yet" },
            { "name": "Destination Address", "value": "255.255.255.255" }
          ]
        },
        {
          "name": "Dynamic Host Configuration Protocol (Request)",
          "fields": [
            { "name": "Transaction ID", "value": "0x3903F326" },
            { "name": "DHCP Message Type", "value": "Request (3)", "highlight": true },
            { "name": "Option 50 - Requested IP", "value": "192.168.1.150", "highlight": true, "description": "Client confirms the offered IP" },
            { "name": "Option 54 - DHCP Server ID", "value": "192.168.1.1", "highlight": true, "description": "Identifies which server's offer is accepted" },
            { "name": "Option 12 - Hostname", "value": "workstation-07" }
          ]
        }
      ]
    },
    {
      "number": 4,
