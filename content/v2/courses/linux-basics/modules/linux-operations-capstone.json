  "schemaVersion": 2,
  "id": "linux-operations-capstone",
  "courseId": "linux-basics",
  "title": "Troubleshooting, Security, Recovery, and Operations Handoff",
  "description": "Resolve a multi-layer workstation incident and hand off a safe, reproducible operating procedure to another technician. Learners cumulatively produce a complete Linux operations evidence portfolio through theory, guided work, debugging, transfer, retrieval, and assessment.",
  "order": 14,
  "objectives": [
    "Form competing hypotheses, select discriminating observations, and update confidence without changing multiple layers at once.",
    "Use privilege only for the smallest justified operation while preserving command provenance, environment boundaries, and audit evidence.",
    "Preview scope, snapshot relevant state, define stop conditions, and test rollback before risky filesystem, package, or service changes."
  ],
