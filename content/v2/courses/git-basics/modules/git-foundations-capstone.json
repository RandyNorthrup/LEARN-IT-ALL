{
  "schemaVersion": 2,
  "id": "git-foundations-capstone",
  "courseId": "git-basics",
  "title": "Repository Repair, Release, and Collaboration Capstone",
  "description": "Recover and ship a repository containing mixed work, a conflict, a mistaken commit, a remote update, and a release deadline. Learners cumulatively produce a complete Git foundations evidence portfolio through theory, guided work, debugging, transfer, retrieval, and assessment.",
  "order": 14,
  "objectives": [
    "Capture repository boundaries, config origins, current operation, worktree/index state, graph, remotes, and recovery refs before repair.",
    "Order preservation, reproduction, local repair, tests, history cleanup, and publication from least to most irreversible.",
    "Coordinate rewritten history, conflicts, ownership, release changes, and recovery instructions with explicit affected refs and people."
  ],
