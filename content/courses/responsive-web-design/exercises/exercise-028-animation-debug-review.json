{
  "id": "exercise-028-animation-debug-review",
  "lessonId": "lesson-028-animation-debug-review",
  "title": "Animation, Debugging, and CSS Review",
  "description": "Animate a progress indicator, then provide a reduced-motion equivalent.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "intermediate",
  "points": 140,
  "language": "html",
  "exerciseType": "lab",
  "starterFiles": {
    "html": "<section class=\"progress-card\">\n  <h1>Course progress</h1>\n  <div class=\"meter\"><span></span></div>\n</section>",
    "css": ".meter span {\n}\n"
  },
  "requirements": [
    {
      "id": "keyframes",
      "type": "source-includes",
      "description": "Define progress animation",
      "source": "css",
      "expected": "@keyframes fill-meter",
      "hint": "Add keyframes."
    },
    {
      "id": "animation",
      "type": "css-property",
      "description": "Apply progress animation",
      "selector": ".meter span",
      "property": "animation",
      "expected": "fill-meter 1s ease-out both",
      "hint": "Set exact animation shorthand."
    },
    {
      "id": "motion",
      "type": "source-includes",
      "description": "Respect reduced-motion preference",
      "source": "css",
      "expected": "prefers-reduced-motion: reduce",
      "hint": "Add media query."
    },
    {
      "id": "contain",
      "type": "source-includes",
      "description": "Use transform-based motion",
      "source": "css",
      "expected": "transform:",
      "hint": "Animate transform rather than width."
    }
  ],
  "hints": [
    "Add keyframes.",
    "Set exact animation shorthand.",
    "Add media query.",
    "Animate transform rather than width."
  ]
}
