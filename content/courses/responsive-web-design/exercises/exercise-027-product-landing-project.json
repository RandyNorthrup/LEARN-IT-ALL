{
  "id": "exercise-027-product-landing-project",
  "lessonId": "lesson-027-product-landing-project",
  "title": "Certification Project: Product Landing Page",
  "description": "Build a responsive landing page for a practice-first learning product.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "advanced",
  "points": 300,
  "language": "html",
  "exerciseType": "project",
  "starterFiles": {
    "html": "<header id=\"header\">\n  <nav id=\"nav-bar\" aria-label=\"Primary\"></nav>\n</header>\n<main>\n  <section class=\"hero\"><h1>Learn by shipping</h1></section>\n</main>",
    "css": "#header {\n}\n.hero {\n}\n"
  },
  "requirements": [
    {
      "id": "nav",
      "type": "selector-exists",
      "description": "Add three navigation links",
      "selector": "#nav-bar .nav-link:nth-child(3)",
      "hint": "Add three .nav-link anchors."
    },
    {
      "id": "video",
      "type": "selector-exists",
      "description": "Include product demonstration video",
      "selector": "video[controls]",
      "hint": "Add video controls."
    },
    {
      "id": "form",
      "type": "selector-exists",
      "description": "Add email interest form",
      "selector": "form input[type=\"email\"][required]",
      "hint": "Use required email input."
    },
    {
      "id": "responsive",
      "type": "source-includes",
      "description": "Adapt layout for wide screens",
      "source": "css",
      "expected": "@media (min-width: 48rem)",
      "hint": "Add a media query."
    }
  ],
  "hints": [
    "Add three .nav-link anchors.",
    "Add video controls.",
    "Use required email input.",
    "Add a media query."
  ]
}
