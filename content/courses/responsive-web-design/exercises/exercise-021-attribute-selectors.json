{
  "id": "exercise-021-attribute-selectors",
  "lessonId": "lesson-021-attribute-selectors",
  "title": "Target Meaningful Attributes",
  "description": "Style file links and disclosure state from their attributes.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "intermediate",
  "points": 140,
  "language": "html",
  "exerciseType": "lab",
  "starterFiles": {
    "html": "<nav class=\"resources\">\n  <a href=\"guide.pdf\">Guide</a>\n  <a href=\"notes.html\">Notes</a>\n  <button type=\"button\" aria-expanded=\"false\">Details</button>\n</nav>",
    "css": ".resources {\n}\n"
  },
  "requirements": [
    {
      "id": "pdf",
      "type": "source-includes",
      "description": "Target PDF links",
      "source": "css",
      "expected": "a[href$=\".pdf\"]",
      "hint": "Use suffix attribute selector."
    },
    {
      "id": "external",
      "type": "source-includes",
      "description": "Target secure external links",
      "source": "css",
      "expected": "a[href^=\"https://\"]",
      "hint": "Use prefix selector."
    },
    {
      "id": "state",
      "type": "source-includes",
      "description": "Target expanded disclosure state",
      "source": "css",
      "expected": "[aria-expanded=\"true\"]",
      "hint": "Use exact ARIA state selector."
    },
    {
      "id": "case",
      "type": "source-includes",
      "description": "Match file extension case-insensitively",
      "source": "css",
      "expected": "i]",
      "hint": "Add case-insensitive flag."
    }
  ],
  "hints": [
    "Use suffix attribute selector.",
    "Use prefix selector.",
    "Use exact ARIA state selector.",
    "Add case-insensitive flag."
  ]
}
