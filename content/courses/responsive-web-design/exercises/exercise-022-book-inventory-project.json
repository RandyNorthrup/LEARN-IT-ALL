{
  "id": "exercise-022-book-inventory-project",
  "lessonId": "lesson-022-book-inventory-project",
  "title": "Certification Project: Book Inventory",
  "description": "Build a filter-ready book inventory with at least three status states.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "advanced",
  "points": 300,
  "language": "html",
  "exerciseType": "project",
  "starterFiles": {
    "html": "<main>\n  <h1>Book Inventory</h1>\n  <div class=\"table-scroll\">\n    <table>\n      <caption>Current collection</caption>\n    </table>\n  </div>\n</main>",
    "css": ".table-scroll {\n}\n"
  },
  "requirements": [
    {
      "id": "headers",
      "type": "selector-exists",
      "description": "Create table column headers",
      "selector": "thead th[scope=\"col\"]",
      "hint": "Use thead and scope col."
    },
    {
      "id": "rows",
      "type": "selector-exists",
      "description": "Add at least three inventory rows",
      "selector": "tbody tr:nth-child(3)",
      "hint": "Add three rows."
    },
    {
      "id": "status",
      "type": "selector-exists",
      "description": "Expose a status data attribute",
      "selector": "tbody tr[data-status]",
      "hint": "Add data-status to rows."
    },
    {
      "id": "overflow",
      "type": "css-property",
      "description": "Keep table usable on narrow screens",
      "selector": ".table-scroll",
      "property": "overflow-x",
      "expected": "auto",
      "hint": "Set overflow-x: auto."
    }
  ],
  "hints": [
    "Use thead and scope col.",
    "Add three rows.",
    "Add data-status to rows.",
    "Set overflow-x: auto."
  ]
}
