{
  "id": "exercise-003-links-images-media",
  "lessonId": "lesson-003-links-images-media",
  "title": "Connect Pages, Images, Audio, and Video",
  "description": "Create a small media gallery with an image, caption, and playable video.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "beginner",
  "points": 140,
  "language": "html",
  "exerciseType": "lab",
  "starterFiles": {
    "html": "<main>\n  <h1>Field Notes</h1>\n  <!-- Build the media figure and video -->\n</main>",
    "css": "img, video {\n  max-width: 100%;\n}\n"
  },
  "requirements": [
    {
      "id": "figure",
      "type": "selector-exists",
      "description": "Group media and caption in a figure",
      "selector": "figure > figcaption",
      "hint": "Nest figcaption in figure."
    },
    {
      "id": "image-alt",
      "type": "attribute-equals",
      "description": "Describe the image",
      "selector": "img",
      "attribute": "alt",
      "expected": "Mountain trail at sunrise",
      "hint": "Use useful alt text."
    },
    {
      "id": "video",
      "type": "selector-exists",
      "description": "Add a video with controls",
      "selector": "video[controls]",
      "hint": "The controls attribute enables playback UI."
    },
    {
      "id": "captions",
      "type": "selector-exists",
      "description": "Provide a caption track",
      "selector": "video track[kind=\"captions\"]",
      "hint": "Use track kind=\"captions\"."
    }
  ],
  "hints": [
    "Nest figcaption in figure.",
    "Use useful alt text.",
    "The controls attribute enables playback UI.",
    "Use track kind=\"captions\"."
  ]
}
