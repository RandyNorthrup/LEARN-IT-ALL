{
  "id": "exercise-016-flexbox-layout",
  "lessonId": "lesson-016-flexbox-layout",
  "title": "One-Dimensional Layout with Flexbox",
  "description": "Build a responsive pricing row that wraps naturally and gives each card fair space.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "intermediate",
  "points": 100,
  "language": "html",
  "exerciseType": "workshop",
  "starterFiles": {
    "html": "<section class=\"plans\">\n  <article class=\"plan\">Starter</article>\n  <article class=\"plan\">Builder</article>\n  <article class=\"plan\">Team</article>\n</section>",
    "css": ".plans {\n}\n.plan {\n}\n"
  },
  "requirements": [
    {
      "id": "display",
      "type": "css-property",
      "description": "Create flex container",
      "selector": ".plans",
      "property": "display",
      "expected": "flex",
      "hint": "Set display: flex."
    },
    {
      "id": "wrap",
      "type": "css-property",
      "description": "Allow narrow screens to wrap",
      "selector": ".plans",
      "property": "flex-wrap",
      "expected": "wrap",
      "hint": "Set flex-wrap: wrap."
    },
    {
      "id": "gap",
      "type": "css-property",
      "description": "Use gap between cards",
      "selector": ".plans",
      "property": "gap",
      "expected": "1rem",
      "hint": "Set gap: 1rem."
    },
    {
      "id": "flex",
      "type": "css-property",
      "description": "Give cards resilient basis",
      "selector": ".plan",
      "property": "flex",
      "expected": "1 1 16rem",
      "hint": "Set flex: 1 1 16rem."
    }
  ],
  "hints": [
    "Set display: flex.",
    "Set flex-wrap: wrap.",
    "Set gap: 1rem.",
    "Set flex: 1 1 16rem."
  ]
}
