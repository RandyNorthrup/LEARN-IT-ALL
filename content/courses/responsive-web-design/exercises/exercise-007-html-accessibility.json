{
  "id": "exercise-007-html-accessibility",
  "lessonId": "lesson-007-html-accessibility",
  "title": "Accessibility as Core HTML",
  "description": "Repair an inaccessible event card using native buttons, headings, labels, and a status region.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "beginner",
  "points": 140,
  "language": "html",
  "exerciseType": "lab",
  "starterFiles": {
    "html": "<div class=\"event-card\">\n  <div class=\"title\">Inclusive Web Meetup</div>\n  <div class=\"action\">Reserve seat</div>\n  <div class=\"message\"></div>\n</div>",
    "css": ".event-card {\n  padding: 1rem;\n}\n"
  },
  "requirements": [
    {
      "id": "heading",
      "type": "text-includes",
      "description": "Create a real heading",
      "selector": "h2",
      "expected": "Inclusive Web Meetup",
      "hint": "Replace visual-only title div with h2."
    },
    {
      "id": "button",
      "type": "text-includes",
      "description": "Use a native action button",
      "selector": "button",
      "expected": "Reserve seat",
      "hint": "Replace action div with button."
    },
    {
      "id": "status",
      "type": "attribute-equals",
      "description": "Announce booking status",
      "selector": ".message",
      "attribute": "role",
      "expected": "status",
      "hint": "Use role=\"status\" for async feedback."
    },
    {
      "id": "focus",
      "type": "source-includes",
      "description": "Add visible keyboard focus style",
      "source": "css",
      "expected": ":focus-visible",
      "hint": "Create a :focus-visible rule."
    }
  ],
  "hints": [
    "Replace visual-only title div with h2.",
    "Replace action div with button.",
    "Use role=\"status\" for async feedback.",
    "Create a :focus-visible rule."
  ]
}
