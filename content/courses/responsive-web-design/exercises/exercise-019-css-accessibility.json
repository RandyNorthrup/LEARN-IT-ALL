{
  "id": "exercise-019-css-accessibility",
  "lessonId": "lesson-019-css-accessibility",
  "title": "Accessible CSS and User Preferences",
  "description": "Repair an animated call-to-action so focus and reduced-motion users receive equivalent feedback.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "intermediate",
  "points": 140,
  "language": "html",
  "exerciseType": "lab",
  "starterFiles": {
    "html": "<a class=\"cta\" href=\"#start\">Start building</a>",
    "css": ".cta {\n  transition: transform 300ms ease;\n}\n.cta:hover {\n  transform: scale(1.08);\n}\n"
  },
  "requirements": [
    {
      "id": "focus",
      "type": "source-includes",
      "description": "Create visible focus style",
      "source": "css",
      "expected": ".cta:focus-visible",
      "hint": "Add focus-visible rule."
    },
    {
      "id": "motion",
      "type": "source-includes",
      "description": "Respect reduced motion",
      "source": "css",
      "expected": "prefers-reduced-motion: reduce",
      "hint": "Add reduced-motion query."
    },
    {
      "id": "target",
      "type": "css-property",
      "description": "Provide usable target height",
      "selector": ".cta",
      "property": "min-height",
      "expected": "44px",
      "hint": "Set min-height: 44px."
    },
    {
      "id": "display",
      "type": "css-property",
      "description": "Make target dimensions apply",
      "selector": ".cta",
      "property": "display",
      "expected": "inline-flex",
      "hint": "Set display: inline-flex."
    }
  ],
  "hints": [
    "Add focus-visible rule.",
    "Add reduced-motion query.",
    "Set min-height: 44px.",
    "Set display: inline-flex."
  ]
}
