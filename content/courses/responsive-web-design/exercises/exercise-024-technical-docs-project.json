{
  "id": "exercise-024-technical-docs-project",
  "lessonId": "lesson-024-technical-docs-project",
  "title": "Certification Project: Technical Documentation",
  "description": "Create a technical documentation page with five linked sections and responsive navigation.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "advanced",
  "points": 300,
  "language": "html",
  "exerciseType": "project",
  "starterFiles": {
    "html": "<a class=\"skip-link\" href=\"#main-doc\">Skip to content</a>\n<nav id=\"navbar\" aria-label=\"Documentation\">\n  <h1>CSS Field Manual</h1>\n</nav>\n<main id=\"main-doc\"></main>",
    "css": "#navbar {\n}\n#main-doc {\n}\n"
  },
  "requirements": [
    {
      "id": "sections",
      "type": "selector-exists",
      "description": "Create five documentation sections",
      "selector": "#main-doc .main-section:nth-child(5)",
      "hint": "Add five .main-section elements."
    },
    {
      "id": "links",
      "type": "selector-exists",
      "description": "Link navigation to sections",
      "selector": "#navbar a[href^=\"#\"]",
      "hint": "Add fragment links."
    },
    {
      "id": "nav",
      "type": "css-property",
      "description": "Keep wide-screen navigation visible",
      "selector": "#navbar",
      "property": "position",
      "expected": "sticky",
      "hint": "Set position sticky."
    },
    {
      "id": "mobile",
      "type": "source-includes",
      "description": "Adapt navigation on narrow screens",
      "source": "css",
      "expected": "@media (max-width: 48rem)",
      "hint": "Add narrow media query."
    }
  ],
  "hints": [
    "Add five .main-section elements.",
    "Add fragment links.",
    "Set position sticky.",
    "Add narrow media query."
  ]
}
