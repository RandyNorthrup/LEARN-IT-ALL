{
  "id": "exercise-005-forms-and-tables",
  "lessonId": "lesson-005-forms-and-tables",
  "title": "Collect and Present Structured Data",
  "description": "Create a workshop signup form beside a compact schedule table.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "beginner",
  "points": 100,
  "language": "html",
  "exerciseType": "workshop",
  "starterFiles": {
    "html": "<main>\n  <h1>Workshop Signup</h1>\n  <form>\n    <!-- Add labeled email control and fieldset -->\n  </form>\n</main>",
    "css": "form {\n  display: grid;\n  gap: 1rem;\n}\n"
  },
  "requirements": [
    {
      "id": "email",
      "type": "attribute-equals",
      "description": "Connect email label and control",
      "selector": "input[type=\"email\"]",
      "attribute": "id",
      "expected": "email",
      "hint": "Give input id=\"email\" and label for=\"email\"."
    },
    {
      "id": "fieldset",
      "type": "selector-exists",
      "description": "Group attendance choices",
      "selector": "fieldset > legend",
      "hint": "Use fieldset and legend."
    },
    {
      "id": "caption",
      "type": "selector-exists",
      "description": "Name the schedule table",
      "selector": "table > caption",
      "hint": "Add a caption as first table child."
    },
    {
      "id": "scope",
      "type": "attribute-equals",
      "description": "Identify column headers",
      "selector": "th",
      "attribute": "scope",
      "expected": "col",
      "hint": "Use scope=\"col\"."
    }
  ],
  "hints": [
    "Give input id=\"email\" and label for=\"email\".",
    "Use fieldset and legend.",
    "Add a caption as first table child.",
    "Use scope=\"col\"."
  ]
}
