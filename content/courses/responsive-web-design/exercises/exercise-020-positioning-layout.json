{
  "id": "exercise-020-positioning-layout",
  "lessonId": "lesson-020-positioning-layout",
  "title": "Normal Flow, Positioning, and Stacking",
  "description": "Create a sticky table-of-contents and anchored notification badge.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "intermediate",
  "points": 100,
  "language": "html",
  "exerciseType": "workshop",
  "starterFiles": {
    "html": "<div class=\"docs\">\n  <nav class=\"toc\" aria-label=\"On this page\">Topics</nav>\n  <main><button class=\"inbox\" type=\"button\">Inbox <span class=\"badge\">3</span></button></main>\n</div>",
    "css": ".toc {\n}\n.inbox {\n}\n.badge {\n}\n"
  },
  "requirements": [
    {
      "id": "sticky",
      "type": "css-property",
      "description": "Keep contents visible while scrolling",
      "selector": ".toc",
      "property": "position",
      "expected": "sticky",
      "hint": "Set position sticky."
    },
    {
      "id": "offset",
      "type": "css-property",
      "description": "Anchor sticky navigation",
      "selector": ".toc",
      "property": "top",
      "expected": "1rem",
      "hint": "Set top: 1rem."
    },
    {
      "id": "anchor",
      "type": "css-property",
      "description": "Create badge containing block",
      "selector": ".inbox",
      "property": "position",
      "expected": "relative",
      "hint": "Set position relative."
    },
    {
      "id": "badge",
      "type": "css-property",
      "description": "Position badge independently",
      "selector": ".badge",
      "property": "position",
      "expected": "absolute",
      "hint": "Set position absolute."
    }
  ],
  "hints": [
    "Set position sticky.",
    "Set top: 1rem.",
    "Set position relative.",
    "Set position absolute."
  ]
}
