{
  "id": "exercise-006-survey-form-project",
  "lessonId": "lesson-006-survey-form-project",
  "title": "Certification Project: Research Survey",
  "description": "Build a complete learner research survey without step-by-step markup instructions.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "advanced",
  "points": 300,
  "language": "html",
  "exerciseType": "project",
  "starterFiles": {
    "html": "<main>\n  <h1>Learner Research Survey</h1>\n  <p id=\"description\">Help us improve practice sessions.</p>\n  <form id=\"survey-form\">\n  </form>\n</main>",
    "css": "body {\n  font-family: system-ui, sans-serif;\n}\n"
  },
  "requirements": [
    {
      "id": "name",
      "type": "selector-exists",
      "description": "Collect a required name",
      "selector": "#survey-form input[name=\"name\"][required]",
      "hint": "Add a required name input."
    },
    {
      "id": "email",
      "type": "selector-exists",
      "description": "Collect a valid required email",
      "selector": "#survey-form input[type=\"email\"][required]",
      "hint": "Use type email and required."
    },
    {
      "id": "radios",
      "type": "selector-exists",
      "description": "Add experience choices",
      "selector": "#survey-form input[type=\"radio\"][name=\"experience\"]",
      "hint": "Radio choices need shared name."
    },
    {
      "id": "submit",
      "type": "selector-exists",
      "description": "Provide a submit action",
      "selector": "#survey-form button[type=\"submit\"]",
      "hint": "Use a submit button."
    }
  ],
  "hints": [
    "Add a required name input.",
    "Use type email and required.",
    "Radio choices need shared name.",
    "Use a submit button."
  ]
}
