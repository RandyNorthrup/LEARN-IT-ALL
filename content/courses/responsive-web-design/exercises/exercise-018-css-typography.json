{
  "id": "exercise-018-css-typography",
  "lessonId": "lesson-018-css-typography",
  "title": "Readable, Resilient Typography",
  "description": "Typeset a long-form article with fluid heading and readable measure.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "intermediate",
  "points": 140,
  "language": "html",
  "exerciseType": "lab",
  "starterFiles": {
    "html": "<article class=\"feature\">\n  <h1>Practice Changes Understanding</h1>\n  <p>Reading introduces an idea. Building makes you test its edges, explain choices, and recover from mistakes.</p>\n</article>",
    "css": ".feature {\n}\n.feature h1 {\n}\n.feature p {\n}\n"
  },
  "requirements": [
    {
      "id": "measure",
      "type": "css-property",
      "description": "Limit article measure",
      "selector": ".feature",
      "property": "max-width",
      "expected": "65ch",
      "hint": "Set max-width: 65ch."
    },
    {
      "id": "leading",
      "type": "css-property",
      "description": "Use readable paragraph leading",
      "selector": ".feature p",
      "property": "line-height",
      "expected": "1.7",
      "hint": "Set line-height: 1.7."
    },
    {
      "id": "balance",
      "type": "css-property",
      "description": "Balance heading lines",
      "selector": ".feature h1",
      "property": "text-wrap",
      "expected": "balance",
      "hint": "Set text-wrap: balance."
    },
    {
      "id": "fluid",
      "type": "css-property",
      "description": "Scale heading fluidly",
      "selector": ".feature h1",
      "property": "font-size",
      "expected": "clamp(2rem,6vw,4rem)",
      "hint": "Use clamp."
    }
  ],
  "hints": [
    "Set max-width: 65ch.",
    "Set line-height: 1.7.",
    "Set text-wrap: balance.",
    "Use clamp."
  ]
}
