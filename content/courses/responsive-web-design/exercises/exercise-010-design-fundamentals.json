{
  "id": "exercise-010-design-fundamentals",
  "lessonId": "lesson-010-design-fundamentals",
  "title": "Design for Real Users",
  "description": "Turn a flat settings panel into a clear hierarchy with reusable tokens.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "beginner",
  "points": 140,
  "language": "html",
  "exerciseType": "lab",
  "starterFiles": {
    "html": "<section class=\"settings\">\n  <h1>Notification settings</h1>\n  <p>Choose how updates reach you.</p>\n  <button type=\"button\">Save preferences</button>\n</section>",
    "css": ":root {\n  /* Add design tokens */\n}\n.settings {\n}\n"
  },
  "requirements": [
    {
      "id": "space-token",
      "type": "source-includes",
      "description": "Create a spacing token",
      "source": "css",
      "expected": "--space-lg:",
      "hint": "Define --space-lg in :root."
    },
    {
      "id": "measure",
      "type": "css-property",
      "description": "Limit line length",
      "selector": ".settings",
      "property": "max-width",
      "expected": "40rem",
      "hint": "Set max-width: 40rem."
    },
    {
      "id": "spacing",
      "type": "css-property",
      "description": "Apply consistent panel spacing",
      "selector": ".settings",
      "property": "padding",
      "expected": "var(--space-lg)",
      "hint": "Use token for padding."
    },
    {
      "id": "button",
      "type": "css-property",
      "description": "Make action visually distinct",
      "selector": ".settings button",
      "property": "font-weight",
      "expected": "700",
      "hint": "Set font-weight: 700."
    }
  ],
  "hints": [
    "Define --space-lg in :root.",
    "Set max-width: 40rem.",
    "Use token for padding.",
    "Set font-weight: 700."
  ]
}
