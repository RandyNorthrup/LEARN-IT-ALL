{
  "id": "exercise-014-styling-forms",
  "lessonId": "lesson-014-styling-forms",
  "title": "Style Forms Without Breaking Them",
  "description": "Style a compact account form with clear focus and invalid states.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "intermediate",
  "points": 140,
  "language": "html",
  "exerciseType": "lab",
  "starterFiles": {
    "html": "<form class=\"account-form\">\n  <label for=\"username\">Username</label>\n  <input id=\"username\" name=\"username\" required>\n  <button type=\"submit\">Create account</button>\n</form>",
    "css": ".account-form {\n}\n.account-form input {\n}\n"
  },
  "requirements": [
    {
      "id": "layout",
      "type": "css-property",
      "description": "Stack controls with grid",
      "selector": ".account-form",
      "property": "display",
      "expected": "grid",
      "hint": "Set display: grid."
    },
    {
      "id": "gap",
      "type": "css-property",
      "description": "Separate form elements",
      "selector": ".account-form",
      "property": "gap",
      "expected": "0.75rem",
      "hint": "Set gap."
    },
    {
      "id": "focus",
      "type": "source-includes",
      "description": "Style keyboard focus",
      "source": "css",
      "expected": "input:focus-visible",
      "hint": "Add focus-visible rule."
    },
    {
      "id": "invalid",
      "type": "source-includes",
      "description": "Explain invalid state visually",
      "source": "css",
      "expected": "input:user-invalid",
      "hint": "Use :user-invalid."
    }
  ],
  "hints": [
    "Set display: grid.",
    "Set gap.",
    "Add focus-visible rule.",
    "Use :user-invalid."
  ]
}
