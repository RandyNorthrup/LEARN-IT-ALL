{
  "id": "exercise-017-playing-cards-project",
  "lessonId": "lesson-017-playing-cards-project",
  "title": "Certification Project: Playing Card Layout",
  "description": "Create a hand of three responsive playing cards using Flexbox.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "advanced",
  "points": 300,
  "language": "html",
  "exerciseType": "project",
  "starterFiles": {
    "html": "<main>\n  <h1>Practice Hand</h1>\n  <section class=\"hand\" aria-label=\"Playing card hand\">\n  </section>\n</main>",
    "css": ".hand {\n}\n.card {\n}\n"
  },
  "requirements": [
    {
      "id": "cards",
      "type": "selector-exists",
      "description": "Create at least three cards",
      "selector": ".hand .card:nth-child(3)",
      "hint": "Add three .card elements."
    },
    {
      "id": "hand-flex",
      "type": "css-property",
      "description": "Lay out hand with Flexbox",
      "selector": ".hand",
      "property": "display",
      "expected": "flex",
      "hint": "Set display flex."
    },
    {
      "id": "hand-wrap",
      "type": "css-property",
      "description": "Allow cards to wrap",
      "selector": ".hand",
      "property": "flex-wrap",
      "expected": "wrap",
      "hint": "Set flex-wrap."
    },
    {
      "id": "card-ratio",
      "type": "css-property",
      "description": "Keep card proportions",
      "selector": ".card",
      "property": "aspect-ratio",
      "expected": "2 / 3",
      "hint": "Set aspect-ratio: 2 / 3."
    }
  ],
  "hints": [
    "Add three .card elements.",
    "Set display flex.",
    "Set flex-wrap.",
    "Set aspect-ratio: 2 / 3."
  ]
}
