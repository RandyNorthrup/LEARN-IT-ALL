{
  "id": "exercise-011-css-units-sizing",
  "lessonId": "lesson-011-css-units-sizing",
  "title": "Size Interfaces with Intent",
  "description": "Create a fluid hero whose type and spacing adapt without breakpoint jumps.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "intermediate",
  "points": 140,
  "language": "html",
  "exerciseType": "lab",
  "starterFiles": {
    "html": "<header class=\"hero\">\n  <h1>Learn by building</h1>\n  <p>Practice on every screen.</p>\n</header>",
    "css": ".hero {\n}\n.hero h1 {\n}\n"
  },
  "requirements": [
    {
      "id": "width",
      "type": "css-property",
      "description": "Use a readable fluid width",
      "selector": ".hero",
      "property": "width",
      "expected": "min(90%, 70rem)",
      "hint": "Use width: min(90%, 70rem)."
    },
    {
      "id": "padding",
      "type": "css-property",
      "description": "Use fluid padding",
      "selector": ".hero",
      "property": "padding",
      "expected": "clamp(1rem,5vw,4rem)",
      "hint": "Use clamp(1rem, 5vw, 4rem)."
    },
    {
      "id": "type",
      "type": "css-property",
      "description": "Use fluid heading size",
      "selector": ".hero h1",
      "property": "font-size",
      "expected": "clamp(2rem,7vw,5rem)",
      "hint": "Use clamp for font-size."
    },
    {
      "id": "margin",
      "type": "css-property",
      "description": "Center the hero",
      "selector": ".hero",
      "property": "margin",
      "expected": "0 auto",
      "hint": "Set margin: 0 auto."
    }
  ],
  "hints": [
    "Use width: min(90%, 70rem).",
    "Use clamp(1rem, 5vw, 4rem).",
    "Use clamp for font-size.",
    "Set margin: 0 auto."
  ]
}
