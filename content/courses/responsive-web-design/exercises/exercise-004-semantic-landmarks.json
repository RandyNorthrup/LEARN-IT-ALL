{
  "id": "exercise-004-semantic-landmarks",
  "lessonId": "lesson-004-semantic-landmarks",
  "title": "Shape Meaning with Semantic HTML",
  "description": "Build a blog article whose landmarks and time metadata remain useful without CSS.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "beginner",
  "points": 100,
  "language": "html",
  "exerciseType": "workshop",
  "starterFiles": {
    "html": "<header>\n  <h1>Signal Journal</h1>\n</header>\n<!-- Add main article and footer -->",
    "css": "body {\n  line-height: 1.6;\n}\n"
  },
  "requirements": [
    {
      "id": "article",
      "type": "selector-exists",
      "description": "Use an article for the post",
      "selector": "main article",
      "hint": "Nest article in main."
    },
    {
      "id": "time",
      "type": "attribute-equals",
      "description": "Provide machine-readable date",
      "selector": "time",
      "attribute": "datetime",
      "expected": "2026-07-13",
      "hint": "Add datetime to time."
    },
    {
      "id": "footer",
      "type": "selector-exists",
      "description": "Add document footer",
      "selector": "body > footer",
      "hint": "Use a footer after main."
    },
    {
      "id": "quote",
      "type": "text-includes",
      "description": "Include the key quotation",
      "selector": "blockquote",
      "expected": "Build for people",
      "hint": "Use blockquote for the quotation."
    }
  ],
  "hints": [
    "Nest article in main.",
    "Add datetime to time.",
    "Use a footer after main.",
    "Use blockquote for the quotation."
  ]
}
