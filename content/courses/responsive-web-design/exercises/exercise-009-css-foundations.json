{
  "id": "exercise-009-css-foundations",
  "lessonId": "lesson-009-css-foundations",
  "title": "CSS Foundations and the Cascade",
  "description": "Style a reading card using low-specificity reusable selectors.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "beginner",
  "points": 100,
  "language": "html",
  "exerciseType": "workshop",
  "starterFiles": {
    "html": "<article class=\"reading-card\">\n  <h1>CSS Without Guessing</h1>\n  <p>Predict the cascade before opening DevTools.</p>\n</article>",
    "css": "/* Add card, heading, and paragraph rules */"
  },
  "requirements": [
    {
      "id": "card-bg",
      "type": "css-property",
      "description": "Give card a white surface",
      "selector": ".reading-card",
      "property": "background",
      "expected": "white",
      "hint": "Set background: white."
    },
    {
      "id": "card-pad",
      "type": "css-property",
      "description": "Add breathing room",
      "selector": ".reading-card",
      "property": "padding",
      "expected": "2rem",
      "hint": "Set padding: 2rem."
    },
    {
      "id": "heading-color",
      "type": "css-property",
      "description": "Use readable heading color",
      "selector": ".reading-card h1",
      "property": "color",
      "expected": "#172033",
      "hint": "Set exact heading color."
    },
    {
      "id": "layer",
      "type": "source-includes",
      "description": "Organize component rules in a cascade layer",
      "source": "css",
      "expected": "@layer components",
      "hint": "Wrap rules in @layer components."
    }
  ],
  "hints": [
    "Set background: white.",
    "Set padding: 2rem.",
    "Set exact heading color.",
    "Wrap rules in @layer components."
  ]
}
