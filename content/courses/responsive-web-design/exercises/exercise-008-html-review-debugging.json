{
  "id": "exercise-008-html-review-debugging",
  "lessonId": "lesson-008-html-review-debugging",
  "title": "HTML Review: Debug the Document",
  "description": "Debug a product card until structure, link purpose, and image alternative pass.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "beginner",
  "points": 140,
  "language": "html",
  "exerciseType": "lab",
  "starterFiles": {
    "html": "<main>\n  <h1>Gear</h1>\n  <div class=\"product\">\n    <img src=\"/rocket.png\">\n    <a href=\"/courses\">Click here</a>\n  </div>\n</main>",
    "css": ".product {\n  border: 1px solid #ccd4e0;\n}\n"
  },
  "requirements": [
    {
      "id": "alt",
      "type": "attribute-equals",
      "description": "Give product image useful alternative text",
      "selector": ".product img",
      "attribute": "alt",
      "expected": "Learning rocket",
      "hint": "Add alt=\"Learning rocket\"."
    },
    {
      "id": "link",
      "type": "text-includes",
      "description": "Make link purpose clear",
      "selector": ".product a",
      "expected": "Explore courses",
      "hint": "Replace Click here."
    },
    {
      "id": "heading",
      "type": "selector-exists",
      "description": "Name the product with a heading",
      "selector": ".product h2",
      "hint": "Add an h2 inside product."
    },
    {
      "id": "article",
      "type": "selector-exists",
      "description": "Use self-contained product markup",
      "selector": "article.product",
      "hint": "Change div.product to article.product."
    }
  ],
  "hints": [
    "Add alt=\"Learning rocket\".",
    "Replace Click here.",
    "Add an h2 inside product.",
    "Change div.product to article.product."
  ]
}
