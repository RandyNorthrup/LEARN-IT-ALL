  "requirements": [
    {
      "id": "display",
      "type": "css-property",
      "description": "Create grid container",
      "selector": ".gallery",
      "property": "display",
      "expected": "grid",
      "hint": "Set display grid."
    },
    {
      "id": "tracks",
      "type": "css-property",
      "description": "Create intrinsic responsive tracks",
      "selector": ".gallery",
      "property": "grid-template-columns",
      "expected": "repeat(auto-fit,minmax(14rem,1fr))",
      "hint": "Use repeat(auto-fit, minmax(14rem, 1fr))."
    },
    {
      "id": "gap",
      "type": "css-property",
      "description": "Separate cards",
      "selector": ".gallery",
      "property": "gap",
      "expected": "1rem",
      "hint": "Set gap."
    },
    {
      "id": "align",
      "type": "css-property",
      "description": "Stretch cards consistently",
      "selector": ".gallery",
      "property": "align-items",
      "expected": "stretch",
      "hint": "Set align-items stretch."
