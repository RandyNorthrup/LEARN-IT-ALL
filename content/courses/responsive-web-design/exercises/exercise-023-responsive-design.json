{
  "id": "exercise-023-responsive-design",
  "lessonId": "lesson-023-responsive-design",
  "title": "Responsive Design from Content Out",
  "description": "Make a lesson dashboard shift from one column to sidebar layout when space permits.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "intermediate",
  "points": 100,
  "language": "html",
  "exerciseType": "workshop",
  "starterFiles": {
    "html": "<div class=\"dashboard\">\n  <aside>Progress</aside>\n  <main>Current lesson</main>\n</div>",
    "css": ".dashboard {\n  display: grid;\n  gap: 1rem;\n}\n"
  },
  "requirements": [
    {
      "id": "base",
      "type": "css-property",
      "description": "Start with one column",
      "selector": ".dashboard",
      "property": "grid-template-columns",
      "expected": "1fr",
      "hint": "Set one base column."
    },
    {
      "id": "media",
      "type": "source-includes",
      "description": "Add content-driven breakpoint",
      "source": "css",
      "expected": "@media (min-width: 48rem)",
      "hint": "Add media query."
    },
    {
      "id": "wide",
      "type": "source-includes",
      "description": "Create sidebar columns in breakpoint",
      "source": "css",
      "expected": "18rem 1fr",
      "hint": "Use 18rem 1fr inside query."
    },
    {
      "id": "container",
      "type": "source-includes",
      "description": "Enable component query context",
      "source": "css",
      "expected": "container-type: inline-size",
      "hint": "Add container-type."
    }
  ],
  "hints": [
    "Set one base column.",
    "Add media query.",
    "Use 18rem 1fr inside query.",
    "Add container-type."
  ]
}
