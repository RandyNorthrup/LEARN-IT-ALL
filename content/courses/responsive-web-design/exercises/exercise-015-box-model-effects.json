{
  "id": "exercise-015-box-model-effects",
  "lessonId": "lesson-015-box-model-effects",
  "title": "Box Model, Overflow, and Effects",
  "description": "Create a clipped profile card with predictable sizing and subtle depth.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "intermediate",
  "points": 100,
  "language": "html",
  "exerciseType": "workshop",
  "starterFiles": {
    "html": "<article class=\"profile-card\">\n  <img src=\"/rocket.png\" alt=\"Learning rocket\">\n  <h1>Build Pilot</h1>\n</article>",
    "css": ".profile-card {\n}\n.profile-card img {\n}\n"
  },
  "requirements": [
    {
      "id": "sizing",
      "type": "css-property",
      "description": "Use predictable box sizing",
      "selector": ".profile-card",
      "property": "box-sizing",
      "expected": "border-box",
      "hint": "Set border-box."
    },
    {
      "id": "clip",
      "type": "css-property",
      "description": "Clip content to rounded card",
      "selector": ".profile-card",
      "property": "overflow",
      "expected": "hidden",
      "hint": "Set overflow: hidden."
    },
    {
      "id": "radius",
      "type": "css-property",
      "description": "Round card corners",
      "selector": ".profile-card",
      "property": "border-radius",
      "expected": "1rem",
      "hint": "Set border-radius."
    },
    {
      "id": "image",
      "type": "css-property",
      "description": "Keep image responsive",
      "selector": ".profile-card img",
      "property": "max-width",
      "expected": "100%",
      "hint": "Set max-width: 100%."
    }
  ],
  "hints": [
    "Set border-box.",
    "Set overflow: hidden.",
    "Set border-radius.",
    "Set max-width: 100%."
  ]
}
