{
  "id": "exercise-025-css-variables",
  "lessonId": "lesson-025-css-variables",
  "title": "Custom Properties and Theme Systems",
  "description": "Create themeable callout components with local overrides and fallbacks.",
  "instructions": [
    "Read requirements and inspect starter files.",
    "Build in small testable changes.",
    "Run tests; use failure evidence and hints.",
    "Check keyboard and narrow-screen behavior before finishing."
  ],
  "difficulty": "intermediate",
  "points": 100,
  "language": "html",
  "exerciseType": "workshop",
  "starterFiles": {
    "html": "<aside class=\"callout\">Default note</aside>\n<aside class=\"callout callout--warning\">Warning note</aside>",
    "css": ":root {\n}\n.callout {\n}\n.callout--warning {\n}\n"
  },
  "requirements": [
    {
      "id": "token",
      "type": "source-includes",
      "description": "Define callout color token",
      "source": "css",
      "expected": "--callout-color:",
      "hint": "Define root token."
    },
    {
      "id": "apply",
      "type": "css-property",
      "description": "Apply token to border",
      "selector": ".callout",
      "property": "border-color",
      "expected": "var(--callout-color)",
      "hint": "Use var()."
    },
    {
      "id": "override",
      "type": "css-property",
      "description": "Override warning token locally",
      "selector": ".callout--warning",
      "property": "--callout-color",
      "expected": "#b45309",
      "hint": "Set local custom property."
    },
    {
      "id": "property",
      "type": "source-includes",
      "description": "Register a typed custom property",
      "source": "css",
      "expected": "@property --callout-color",
      "hint": "Use @property."
    }
  ],
  "hints": [
    "Define root token.",
    "Use var().",
    "Set local custom property.",
    "Use @property."
  ]
}
