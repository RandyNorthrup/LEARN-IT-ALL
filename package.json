{
  "name": "learn-it-all",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@12.0.1",
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=12.0.1 <13"
  },
  "allowScripts": {
    "agent-browser@0.32.0": true,
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true
  },
  "scripts": {
    "dev": "next dev",
    "predev": "npm run curriculum:runtime:index",
    "build": "next build",
    "prebuild": "npm run curriculum:runtime:index",
    "start": "next start",
    "lint": "biome check src scripts",
    "lint:strict": "biome check --diagnostic-level=warn src scripts",
    "lint:fix": "biome check --write src scripts",
    "test": "vitest run",
    "pretest": "npm run curriculum:runtime:index",
    "test:watch": "vitest",
    "runtime:sql:sync": "node scripts/sync-sql-runtime.mjs",
    "runtime:python:sync": "node scripts/sync-python-runtime.mjs",
    "runtime:go:sync": "node scripts/sync-go-runtime.mjs",
    "curriculum:audit:duplication": "tsx scripts/audit-v2-duplication.ts",
    "curriculum:audit:learning-quality": "tsx scripts/audit-v2-learning-quality.ts",
    "curriculum:audit:research": "tsx scripts/audit-research-program.ts",
    "curriculum:runtime:index": "node scripts/compile-curriculum-runtime-index.mjs",
    "curriculum:reference:rwd": "node scripts/import-fcc-rwd-reference.mjs",
    "curriculum:research:rwd-html": "node scripts/compile-rwd-html-concept-research.mjs",
    "curriculum:research:rwd-css": "node scripts/compile-rwd-css-concept-research.mjs",
    "curriculum:research:rwd-alignment": "node scripts/compile-rwd-concept-alignment.mjs",
    "curriculum:research:rwd-architecture": "node scripts/compile-rwd-research-architecture.mjs",
    "curriculum:research:rwd:check": "node scripts/compile-rwd-html-concept-research.mjs --check && node scripts/compile-rwd-css-concept-research.mjs --check && node scripts/compile-rwd-concept-alignment.mjs --check && node scripts/compile-rwd-research-architecture.mjs --check",
    "lighthouse": "node scripts/run-lighthouse-after-content.mjs all",
    "lighthouse:ci": "node scripts/run-lighthouse-after-content.mjs all",
    "lighthouse:tablet": "node scripts/run-lighthouse-after-content.mjs tablet",
    "lighthouse:desktop": "node scripts/run-lighthouse-after-content.mjs desktop",
    "type-check": "tsc --noEmit",
    "format": "biome format --write src scripts",
    "format:check": "biome format src scripts",
    "mocks:scan": "grep -r 'MOCK\\|TODO\\|FIXME' src/ --include='*.ts' --include='*.tsx' || true"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.2.0",
    "codemirror": "^6.0.2",
    "css-tree": "^3.2.1",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "pyodide": "^314.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "sql.js": "^1.14.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "agent-browser": "^0.32.0",
    "lighthouse": "^13.4.0",
    "proxy-agent": "^8.0.2",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@sentry/node": "^10.65.0",
    "dompurify": "^3.4.12",
    "lighthouse": "^13.4.0",
    "postcss": "^8.5.19",
    "tmp": "^0.2.7",
    "uuid": "^11.1.1"
  }
}
